PORT=5001

# ── Postgres ─────────────────────────────────────────────────────────────────
# These match the docker-compose.yml defaults — do not change for local dev.
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=via_mvp
POSTGRES_HOST=postgres

# ── Authentication ────────────────────────────────────────────────────────────
# JWT_SECRET: signs session tokens. Use any random string locally.
# For production, generate with: openssl rand -hex 32
JWT_SECRET=dev_jwt_secret_change_me_0123456789abcdef

# ADMIN_SECRET: required to register any new user account.
# Share this with your teammates so they can register their own accounts.
# Change this to something private before deploying to production.
ADMIN_SECRET=dev_admin_secret_change_me

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Optional: set a server-side key so users don't need to enter their own.
# If left blank, users must enter their own key in the Settings panel.
OPENAI_API_KEY=sk-xxxxxx

# ── US Census API ─────────────────────────────────────────────────────────────
# Required for the demographic heatmap. Free signup:
# https://api.census.gov/data/key_signup.html
# The key below is a shared dev key — replace with your own for production.
CENSUS_API_KEY=f805edcf2467e1a44d01133ce2018dae58f3b5cb

# Optional: ACS 5-year vintage (defaults to 2022)
# CENSUS_ACS_YEAR=2022

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Defaults to localhost:5173 if unset.
# ALLOWED_ORIGINS=https://your-production-domain.com
