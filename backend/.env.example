PORT=5001

# Postgres Configuration
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=via_mvp
POSTGRES_HOST=postgres

# Authentication
# IMPORTANT: Generate a strong, random 64-character hex string for production.
# Do NOT use weak secrets. Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_a_secure_random_string

# Admin registration secret — required to create any user account.
# CRITICAL: Must be set before first deployment. Empty string allows anyone to register.
ADMIN_SECRET=replace_with_a_strong_admin_secret

# CORS allowed origins (comma-separated). Defaults to localhost:5173 if unset.
# ALLOWED_ORIGINS=https://your-production-domain.com

# OpenAI Configuration
OPENAI_API_KEY=sk-xxxxxx
